# Copy this file to .env.local and fill in your values

# Clerk Authentication (from https://clerk.com → Your App → API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Railway backend URL + /api/__clerk  (e.g. https://your-app.railway.app/api/__clerk)
VITE_CLERK_PROXY_URL=https://YOUR-RAILWAY-BACKEND.railway.app/api/__clerk
